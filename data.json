          "display_step": 5
        },
        {
          "title": "Step 6: Combine",
          "subtitle": "Pour wet mixture into flour mixture",
          "body": "Stir until just combined — don't overmix.",
          "image": "muffins-step6-combine.png",
          "display_step": 6
        },
        {
          "title": "Step 7: Add the apples",
          "subtitle": "Dice apples and fold them in",
