          "display_step": 7
        },
        {
          "title": "Step 8: Fill the muffin tin",
          "subtitle": "Spoon batter into each cup, filling to the top",
          "body": "Use a spoon or ice cream scoop for even filling.",
          "image": "muffins-step8-fill-tin.png",
          "display_step": 8
        },
        {
          "title": "Step 9: Make the topping",
          "subtitle": "Stir together in a small bowl",
          "body": "½ cup brown sugar · ⅓ cup flour · 2 tbsp butter · cinnamon to taste",
          "image": "muffins-step9-topping-mix.png",
          "display_step": 9
        },
        {
          "title": "Step 10: Add the topping",
          "subtitle": "Sprinkle mixture on top of muffins",
